{
  "name": "risbridge-backend",
  "version": "1.0.0",
  "description": "RIS Bridge — SATUSEHAT Imaging Interoperability Platform Backend",
  "main": "dist/server.js",
  "scripts": {
    "dev": "dotenv -e ../.env -- tsx watch src/server.ts",
    "build": "tsc",
    "start": "dotenv -e ../.env -- node dist/server.js",
    "seed": "dotenv -e ../.env -- tsx prisma/seed.ts",
    "db:migrate": "dotenv -e ../.env -- prisma migrate dev",
    "db:generate": "dotenv -e ../.env -- prisma generate",
    "db:push": "dotenv -e ../.env -- prisma db push",
    "db:studio": "dotenv -e ../.env -- prisma studio",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/basic-auth": "^6.0.1",
    "@fastify/cors": "^10.0.1",
    "@fastify/multipart": "^9.0.1",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^8.0.3",
    "@prisma/client": "^6.2.1",
    "axios": "^1.7.9",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.31.0",
    "dayjs": "^1.11.13",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "ioredis": "^5.4.2",
    "jsonwebtoken": "^9.0.2",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "uuid": "^11.0.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.6",
    "@types/uuid": "^10.0.0",
    "dotenv-cli": "^11.0.0",
    "prisma": "^6.2.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
