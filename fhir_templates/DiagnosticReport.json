{
  "resourceType": "DiagnosticReport",
  "identifier": [
    {
      "system": "http://sys-ids.kemkes.go.id/diagnostic/{{organizationId}}/rad",
      "use": "official",
      "value": "{{organizationId}}"
    }
  ],
  "status": "final",
  "category": [
    {
      "coding": [
        {
          "system": "http://terminology.hl7.org/CodeSystem/v2-0074",
          "code": "RAD",
          "display": "Radiology"
        }
      ]
    }
  ],
  "code": {
    "coding": [
      {
        "system": "http://loinc.org",
        "code": "{{loincCode}}",
        "display": "{{loincDisplay}}"
      }
    ]
  },
  "subject": {
    "reference": "Patient/{{patientId}}"
  },
  "encounter": {
    "reference": "Encounter/{{encounterId}}"
  },
  "effectiveDateTime": "{{effectiveDateTime}}",
  "issued": "{{issuedDateTime}}",
  "performer": [
    {
      "reference": "Practitioner/{{performerId}}",
      "display": "{{performerName}}"
    },
    {
      "reference": "Organization/{{organizationId}}"
    }
  ],
  "imagingStudy": [
    {
      "reference": "ImagingStudy/{{imagingStudyId}}"
    }
  ],
  "result": [
    {
      "reference": "Observation/{{observationId}}"
    }
  ],
  "basedOn": [
    {
      "reference": "ServiceRequest/{{serviceRequestId}}"
    }
  ],
  "conclusion": "{{conclusion}}"
}
