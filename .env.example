# ==============================================================================
# RIS Bridge — Environment Configuration
# ==============================================================================
# Copy this file to .env and fill in the values.
# cp .env.example .env
# ==============================================================================

# ------------------------------------------------------------------------------
# Application
# ------------------------------------------------------------------------------
NODE_ENV=development
APP_PORT=3000
APP_HOST=0.0.0.0

# ------------------------------------------------------------------------------
# JWT Authentication
# ------------------------------------------------------------------------------
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-this-to-a-strong-secret-key
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# ------------------------------------------------------------------------------
# PostgreSQL Database
# ------------------------------------------------------------------------------
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mini_ris

# ------------------------------------------------------------------------------
# Redis
# ------------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ------------------------------------------------------------------------------
# SATUSEHAT Integration
# ------------------------------------------------------------------------------
# Base URL for SATUSEHAT FHIR API
# Sandbox : https://api-satusehat-stg.dto.kemkes.go.id
# Production : https://api-satusehat.kemkes.go.id
SATUSEHAT_BASE_URL=https://api-satusehat-stg.dto.kemkes.go.id

# Auth URL for token retrieval
SATUSEHAT_AUTH_URL=https://api-satusehat-stg.dto.kemkes.go.id/oauth2/v1

# Organization ID (from SATUSEHAT platform)
SATUSEHAT_ORG_ID=

# Client credentials (from SATUSEHAT platform)
SATUSEHAT_CLIENT_KEY=
SATUSEHAT_SECRET_KEY=

# ------------------------------------------------------------------------------
# DICOM Router
# ------------------------------------------------------------------------------
# AE Title of the DICOM Router
DICOM_ROUTER_AE_TITLE=DCMROUTER
DICOM_ROUTER_HOST=127.0.0.1
DICOM_ROUTER_PORT=11112

# Container runtime: docker | podman
CONTAINER_RUNTIME=docker

# DICOM Router container name
DICOM_ROUTER_CONTAINER=dicom-router

# ------------------------------------------------------------------------------
# DICOM Storage & Retention Policy
# ------------------------------------------------------------------------------
# Path folder penyimpanan DICOM sementara (relatif terhadap root project)
STORAGE_PATH=./storage

# Batas maksimum penyimpanan dalam GB (default: 40 GB)
# Saat storage melebihi batas ini, FIFO cleanup otomatis dijalankan
STORAGE_MAX_GB=40

# Strategi cleanup: FIFO (First In First Out) — berdasarkan studi tertua
STORAGE_CLEANUP_STRATEGY=FIFO

# Hanya cleanup studi dengan status COMPLETED (true = aman, jangan ubah)
STORAGE_CLEANUP_ONLY_COMPLETED=true

# Aktifkan auto cleanup saat storage limit terlampaui (true/false)
STORAGE_AUTO_CLEANUP=true

# Maksimum retry pengiriman DICOM ke router sebelum file dihapus otomatis
STORAGE_MAX_RETRY_COUNT=3

# Hapus file DICOM fisik saat retry melebihi batas (true/false)
STORAGE_DELETE_FAILED_DICOM_AFTER_RETRY=true

# ------------------------------------------------------------------------------
# Institution (for DICOM metadata injection)
# ------------------------------------------------------------------------------
INSTITUTION_NAME=Rumah Sakit Contoh

# ------------------------------------------------------------------------------
# Webhook (DICOM Router callback)
# ------------------------------------------------------------------------------
WEBHOOK_USERNAME=risbridge
WEBHOOK_PASSWORD=risbridge-webhook-secret
WEBHOOK_CALLBACK_URL=http://host.docker.internal:3000/api/dicom-router/callback

# ------------------------------------------------------------------------------
# DICOM Router Extra Configuration
# ------------------------------------------------------------------------------
DICOM_ROUTER_TZ=Asia/Jakarta
DICOM_ROUTER_HTTP_PORT=8089
DICOM_ROUTER_PATHSUFFIX_DICOM=/dicom/v1/dicomWeb/studies
DICOM_ROUTER_PATHSUFFIX_FHIR=/fhir-r4/v1

# ------------------------------------------------------------------------------
# Logging
# ------------------------------------------------------------------------------
LOG_LEVEL=info
